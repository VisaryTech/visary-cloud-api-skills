{
  "model": {
    "schema": "assets/index/board.json#model",
    "collection": true,
    "fields": {
      "id": "integer:int32",
      "hidden": "boolean",
      "title": "string nullable",
      "projectId": "integer:int32",
      "projectTitle": "string nullable",
      "milestoneId": "integer:int32 nullable",
      "milestoneTitle": "string nullable",
      "sprintId": "integer:int32 nullable",
      "sprintTitle": "string nullable",
      "useCurrentSprint": "boolean",
      "weight": "integer:int32 nullable",
      "hideBacklogList": "boolean",
      "hideClosedList": "boolean",
      "assignees": "array[Visary.Users.Integration.UseCases.Users.Models.UserEasyReadModel]",
      "labels": "array[assets/index/labelfortaskregistry.json#model]"
    }
  },
  "methods": [
    {
      "key": "GET /Board",
      "cliShape": "python api.py -m get_board --arg project_id=<value>",
      "summary": "get board"
    },
    {
      "key": "GET /Board/query/Get/{boardId}",
      "cliShape": "python api.py -m get_board_query_get_board_id --posarg <board_id>",
      "summary": "get board board id"
    },
    {
      "key": "GET /Board/query/GetObjectPermissions/{boardId}",
      "cliShape": "python api.py -m get_board_query_get_object_permissions_board_id --posarg <board_id>",
      "summary": "get board object permissions board id"
    },
    {
      "key": "GET /Board/query/GetTypePermissions",
      "cliShape": "python api.py -m get_board_query_get_type_permissions --arg project_id=<value>",
      "summary": "get board type permissions"
    },
    {
      "key": "POST /Board/command/Create",
      "cliShape": "python api.py -m post_board_command_create --arg body=<json>",
      "summary": "post board create"
    },
    {
      "key": "PATCH /Board/command/Update/{boardId}",
      "cliShape": "python api.py -m patch_board_command_update_board_id --posarg <board_id> --arg body=<json>",
      "summary": "patch board update board id"
    },
    {
      "key": "DELETE /Board/command/Delete/{boardId}",
      "cliShape": "python api.py -m delete_board_command_delete_board_id --posarg <board_id>",
      "summary": "delete board board id"
    },
    {
      "key": "POST /Board/command/Restore/{boardId}",
      "cliShape": "python api.py -m post_board_command_restore_board_id --posarg <board_id>",
      "summary": "post board restore board id"
    },
    {
      "key": "GET /odata/Board",
      "cliShape": "python api.py -m odata_board --arg project_id=<value> --odata-arg '$filter=<value>' --odata-arg '$select=<value>' --odata-arg '$expand=<value>' --odata-arg '$top=<value>' --odata-arg '$skip=<value>' --odata-arg '$orderby=<value>' --odata-arg '$count=<true|false>'",
      "summary": "odata board"
    },
    {
      "key": "GET /odata/Board/$count",
      "cliShape": "python api.py -m odata_board_count --arg project_id=<value> --odata-arg '$filter=<value>'",
      "summary": "odata board count"
    }
  ]
}
