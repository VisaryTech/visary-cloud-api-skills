{
  "model": {
    "schema": "assets/index/label.json#model",
    "collection": true,
    "fields": {
      "id": "integer:int32",
      "hidden": "boolean",
      "scopeId": "integer:int32 nullable",
      "scopeType": "Visary.TaskTracker.Entities.Enums.LabelScopeType",
      "title": "string nullable",
      "description": "string nullable",
      "backgroundColor": "string nullable",
      "taskStatus": "Visary.Tasks.Abstractions.Enums.VisaryTaskStatus"
    }
  },
  "methods": [
    {
      "key": "GET /LabelForProject",
      "cliShape": "python api.py -m get_label_for_project --arg project_id=<value>",
      "summary": "get label for project"
    },
    {
      "key": "GET /odata/LabelForProject",
      "cliShape": "python api.py -m odata_label_for_project --arg project_id=<value> --odata-arg '$filter=<value>' --odata-arg '$select=<value>' --odata-arg '$expand=<value>' --odata-arg '$top=<value>' --odata-arg '$skip=<value>' --odata-arg '$orderby=<value>' --odata-arg '$count=<true|false>'",
      "summary": "odata label for project"
    },
    {
      "key": "GET /odata/LabelForProject/$count",
      "cliShape": "python api.py -m odata_label_for_project_count --arg project_id=<value> --odata-arg '$filter=<value>'",
      "summary": "odata label for project count"
    }
  ]
}
